<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Home</title>
    <!-- Font Awesome CDN for icons -->
     <head><link rel="stylesheet" href="/output.css"></head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <!-- Link to external CSS -->
    <!-- <link rel="stylesheet" href="/form.css"> -->
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen font-sans">

    <form action='/host/save-edited-home/<%=home_.id.toString()%>' method='POST' class="bg-white p-8 rounded-2xl shadow-2xl w-full max-w-md">
        <h2 class="text-3xl font-extrabold text-gray-800 mb-6 text-center">Submit Your Home</h2>

        <div class="form-group relative mb-4">
            <input type='text' name='housename' placeholder='Enter your home name' value = <%=home.housename%>
                   class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"/>
            <i class="fa-solid fa-house absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
        </div>

        <div class="form-group relative mb-4">
            <input type='number' name='cost' placeholder='Enter cost per night' value = <%=home.cost%>
                   class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"/>
            <i class="fa-solid fa-rupee-sign absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
        </div>

        <div class="form-group relative mb-4">
            <input type='text' name='location' placeholder='Enter location' value = <%=home.location%>
                   class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"/>
            <i class="fa-solid fa-location-dot absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
        </div>

        <div class="form-group relative mb-6">
            <input type="text" name="rating" placeholder="Enter rating (out of 5)" value = <%=home.rating%>
                   class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"/>
            <i class="fa-solid fa-star absolute left-3 top-1/2 transform -translate-y-1/2 text-yellow-400"></i>
        </div>

        <div class="form-group relative mb-6">
            <input type="text" name="description" placeholder="Enter home description" value = <%=home.description%>
                class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"/>
            <i class="fa-solid fa-pen absolute left-3 top-1/2 transform -translate-y-1/2 text-yellow-400"></i>
        </div>

        <button type='submit' class="w-full py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition text-lg">
            Save
        </button>
    </form>    

</body>
</html>