<%- include('../../partials/head',{title : 'details' }) %>

    <head>
        <link rel="stylesheet" href="/output.css">
    </head>

    <body
        class="bg-gradient-to-br from-black via-blue-950 to-black min-h-screen flex items-center justify-center p-10 text-blue-200">

        <div class="w-full max-w-5xl">

            <!-- Title -->
            <h1 class="text-4xl font-bold text-center text-yellow-400 mb-12 tracking-wide">
                Property Details
            </h1>

            <!-- Main Container -->
            <div class="bg-blue-950/70 border border-yellow-500/30 shadow-2xl rounded-2xl p-10 backdrop-blur-lg">

                <!-- ID Badge -->
                <div class="flex justify-center mb-10">
                    <span class="bg-yellow-400 text-black px-5 py-2 rounded-full font-bold shadow-lg">
                        ID : <%= homeID %>
                    </span>
                </div>

                <!-- Info Cards -->
                <div class="grid md:grid-cols-2 gap-8">

                    <!-- Name Card -->
                    <div
                        class="bg-black/60 border border-blue-800 rounded-xl p-6 hover:border-yellow-400 hover:shadow-yellow-500/20 hover:shadow-lg transition">
                        <p class="text-yellow-400 text-sm uppercase tracking-widest">House Name</p>
                        <h2 class="text-2xl font-semibold text-blue-300 mt-2">
                            <%= homeObj.housename %>
                        </h2>
                    </div>

                    <!-- Location Card -->
                    <div
                        class="bg-black/60 border border-blue-800 rounded-xl p-6 hover:border-yellow-400 hover:shadow-yellow-500/20 hover:shadow-lg transition">
                        <p class="text-yellow-400 text-sm uppercase tracking-widest">Location</p>
                        <h2 class="text-2xl font-semibold text-blue-300 mt-2">
                            <%= homeObj.location %>
                        </h2>
                    </div>

                    <!-- Rating Card -->
                    <div
                        class="bg-black/60 border border-blue-800 rounded-xl p-6 hover:border-yellow-400 hover:shadow-yellow-500/20 hover:shadow-lg transition">
                        <p class="text-yellow-400 text-sm uppercase tracking-widest">Rating</p>
                        <h2 class="text-2xl font-semibold text-blue-300 mt-2">⭐ <%= homeObj.rating %>
                        </h2>
                    </div>

                    <!-- Price Card -->
                    <div
                        class="bg-black/60 border border-blue-800 rounded-xl p-6 hover:border-yellow-400 hover:shadow-yellow-500/20 hover:shadow-lg transition">
                        <p class="text-yellow-400 text-sm uppercase tracking-widest">Price</p>
                        <h2 class="text-2xl font-bold text-yellow-300 mt-2">₹ <%= homeObj.cost %>
                        </h2>
                    </div>

                </div>

                <div style="border: 1px solid #ccc; 
            padding: 15px; 
            margin: 10px 0; 
            border-radius: 10px; 
            background: #f9f9f9; 
            box-shadow: 0 2px 5px rgba(0,0,0,0.1); 
            font-family: Arial, sans-serif;
            color: #333;">
                    <strong>Description of House:</strong>
                    <p style="margin: 8px 0 0 0; line-height: 1.5;">
                        <%= homeObj.description %>
                    </p>
                </div>

                <!-- Buttons -->
                <div class="flex justify-center gap-8 mt-12">

                    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-6">

                        <a href="http://localhost:4002/user/book-home"
                            class="inline-block transform active:scale-95 transition-transform">
                            <button
                                class="w-48 px-6 py-3 bg-rose-600 text-black font-bold rounded-xl shadow-lg shadow-rose-900/30 hover:bg-rose-500 hover:-translate-y-1 transition-all duration-200">
                                Book Now
                            </button>
                        </a>

                        <a href="http://localhost:4002/"
                            class="inline-block transform active:scale-95 transition-transform">
                            <button
                                class="w-48 px-6 py-3 bg-emerald-600 text-black font-bold rounded-xl shadow-lg shadow-emerald-900/30 hover:bg-emerald-500 hover:-translate-y-1 transition-all duration-200">
                                Go To Home
                            </button>
                        </a>

                    </div>
                </div>

            </div>

        </div>

    </body>