<%- include('../../partials/head.ejs', {title : 'Home Not Found'}) %>
<head><link rel="stylesheet" href="/output.css"></head>
<!-- <head><link rel="stylesheet" href="/404.css"/></head> -->
<body class="bg-gray-100 flex items-center justify-center min-h-screen">
    <div class="text-center">
        <h1 class="text-6xl font-extrabold text-gray-800 mb-4">404</h1>
        <h2 class="text-2xl text-gray-600">Home Not Found</h2>
        <p class="text-xl text-gray-200">
            Home with id = 
            <span class="font-bold text-yellow-400"><%= ID %></span> 
            is not found!!
        </p>
        <p class="text-gray-400 mt-4 text-sm">
            The home you are looking for might have been removed or never existed.
        </p>
        <a href="/" class="mt-6 inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
            Go Home
        </a>
    </div>
</body>
</html>