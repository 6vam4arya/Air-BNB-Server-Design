<%- include('../partials/head', { title: 'Home Page' }) %>
<head><link rel="stylesheet" href="/output.css"></head>
<!-- <head><link rel="stylesheet" href="/home.css"/></head> -->
<body class="bg-gray-50 min-h-screen font-sans">

    <!-- Navbar -->
    <nav class="bg-white shadow-md w-full p-4 flex justify-center space-x-6 sticky top-0 z-10">
        <a href="http://localhost:4002/host/host-home" class="text-blue-600 font-semibold hover:text-blue-800 transition">Add Home</a>
        <a href="http://localhost:4002/user/book-home" class="text-blue-600 font-semibold hover:text-blue-800 transition">Book Home</a>
        <a href="http://localhost:4002/user/favourites/homes" class="text-blue-600 font-semibold hover:text-blue-800 transition">Your Favourites</a>
    </nav>

    <!-- Page Header -->
    <header class="text-center mt-10 mb-8">
        <h1 class="text-5xl font-extrabold text-gray-800 mb-2">Welcome to AirBNB</h1>
        <h3 class="text-xl text-gray-600">Homes you registered :-</h3>
    </header>

    <!-- Home Listings -->
    <main class="max-w-5xl mx-auto px-4">
        <!--{{details of home 1(in k-v) }, {details of home 2}}-->
        <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% registeredhomes.forEach((home, index) => { %>
                <li class="bg-white rounded-xl shadow-lg p-6 hover:shadow-2xl transition relative">
                    <div class="mb-4">
                        <strong class="text-lg text-gray-800"><%= index + 1 %>.</strong>
                        <span class="ml-1 text-gray-700 font-medium"><%= home.houseName %></span>
                    </div>
                    <p class="text-gray-600">Cost: Rs <%= home.cost %></p>
                    <p class="text-gray-600">Location: <%= home.location %></p>
                    <p class="text-gray-600">Registered Home ID: <%= home.id %></p>
                    <p class="text-yellow-500 font-semibold">Rating: <%= home.rating %> ★</p>
                    <div class="mt-4 flex gap-3">
                        <a href='http://localhost:4002/user/book-home'>
                            <button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Book</button>
                        </a>
                        <a href='http://localhost:4002/user/fav/<%=home.id%>'>
                            <button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Add To Favourites</button>
                        </a>
                        <a href='http://localhost:4002/user/<%=home.id%>'>
                            <button class="px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 transition">Details</button>
                        </a>
                    </div>
                </li>
            <% }) %>
        </ul>
    </main>

</body>
</html>