<%- include('../partials/head', { title: 'Home Page' }) %>

<head>
    <link rel="stylesheet" href="/output.css">
</head>
<!-- <head><link rel="stylesheet" href="/home.css"/></head> -->

<body class="bg-gradient-to-br from-sky-100 via-white to-yellow-100 min-h-screen font-sans">

    <!-- Navbar -->
    <nav class="bg-white/70 backdrop-blur-md shadow-md w-full py-4 flex justify-center gap-10 sticky top-0 z-50 border-b border-gray-200">
        <a href="http://localhost:4002/host/host-home"
            class="text-sky-700 font-semibold hover:text-orange-600 transition duration-300">
            Add Home
        </a>
    </nav>

    <header
        class="relative text-center mt-16 mb-14 px-6 py-14 max-w-4xl mx-auto rounded-3xl 
               bg-white/80 backdrop-blur-xl shadow-2xl border border-white/50 overflow-hidden">

        <!-- Subtle soft highlight behind -->
         <div class="absolute -top-10 -left-10 w-40 h-40 bg-orange-300 rounded-full blur-3xl opacity-60"></div>
        <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-yellow-400 rounded-full blur-3xl opacity-30"></div>

        <div class="relative z-10">
            <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 tracking-tight leading-tight">
                Welcome to
                <span class="bg-orange-400 bg-clip-text text-transparent">
                    Airbnb
                </span>
            </h1>

            <p class="mt-5 text-lg text-gray-800 font-medium">
                Welcome Host
            </p>

            <p class="mt-2 text-sm text-gray-700 tracking-wide">
                Homes you’ve added
            </p>
        </div>
    </header>

    <!-- Home Listings -->
    <main class="max-w-6xl mx-auto px-6 pb-12">
        <!--{{details of home 1(in k-v) }, {details of home 2}}-->

        <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

            <% registeredhomes.forEach((home, index)=> { %>

                <li class="relative bg-white/90 backdrop-blur-lg rounded-2xl shadow-lg p-6 
                           hover:shadow-2xl hover:-translate-y-1 transition duration-300 border border-white/50">

                    <!-- subtle glow on hover -->
                    <div class="absolute inset-0 rounded-2xl bg-gradient-to-r from-sky-300 via-orange-300 to-yellow-300 
                                opacity-0 hover:opacity-20 blur-xl transition"></div>

                    <div class="relative z-10">
                        <div class="mb-4">
                            <strong class="text-lg text-sky-700 font-bold">
                                <%= index + 1 %>.
                            </strong>
                            <span class="ml-2 text-gray-900 font-semibold text-lg">
                                <%= home.housename %>
                                <%const Id = home._id.toString();%> <!--⭐-->
                              <a href='http://localhost:4002/user/<%=Id%>'>
                                  <button class="bg-blue-500 text-sm text-white font-semibold py-2 px-6 rounded-lg shadow-md hover:bg-orange-600 hover:shadow-lg active:bg-orange-700 transition duration-200">
                                      Get Details
                                  </button>
                              </a>
                            </span>
                        </div>

                        <!-- Updated text colors for better visibility -->
                        <p class="text-gray-800">💰 Cost: <span class="font-semibold">Rs <%= home.cost %></span></p>
                        <p class="text-gray-800">📍 Location: <%= home.location %></p>
                        <p class="text-gray-600 text-sm">ID: <%= home.id %></p>

                        <p class="mt-2 text-orange-500 font-semibold text-lg">
                            ⭐ <%= home.rating %>
                        </p>

                        <div class="mt-5 flex flex-wrap gap-3">
                            <%let a = home._id.toString();%>

                            <a href='http://localhost:4002/host/edit/<%=a%>'> <!--⭐-->
                                <button class="bg-yellow-500 text-white font-semibold py-2 px-6 rounded-lg shadow-md hover:bg-orange-600 hover:shadow-lg active:bg-orange-700 transition duration-200">
                                    Edit
                                </button>
                            </a>

                            <a href='http://localhost:4002/host/delete/<%=home._id%>'>
                                <button class="bg-orange-500 text-white font-semibold py-2 px-6 rounded-lg shadow-md hover:bg-orange-600 hover:shadow-lg active:bg-orange-700 transition duration-200">
                                    Delete
                                </button>
                            </a>

                        </div>
                    </div>

                </li>

            <% }) %>

        </ul>
    </main>

</body>

</html>

<!--  ⭐ _id of home object is of 'Object ID type' which does not work in JS-->